#!/bin/bash
# Linexin Sound Fix for USB DACs
# Prevents audio from being silent until 30% volume
if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root" 
   exit 1
fi
echo "Applying software mixer override for USB audio..."
# Logic to force software mixing in pipewire/wireplumber
mkdir -p /etc/pipewire/pipewire.conf.d
cat << 'EOP' > /etc/pipewire/pipewire.conf.d/10-usb-soft-mixer.conf
context.properties = {
    default.clock.rate          = 48000
    default.clock.quantum       = 1024
    default.clock.min-quantum   = 32
    default.clock.max-quantum   = 2048
}
EOP
echo "Done. Please restart your audio session."
