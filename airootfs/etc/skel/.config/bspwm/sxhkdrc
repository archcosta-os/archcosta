# Sxhkdrc - ArchCosta BSPWM

# === TERMINAL ===
super + Return
    alacritty

# === MENU ===
super + d
    rofi -show drun

super + shift + d
    rofi -show run

# === WINDOW ===
super + q
    bspc node -c

super + shift + q
    bspc node -k

super + f
    bspc node -t floating
    bspc node -t tiled

super + t
    bspc desktop -l next

super + space
    bspc node -t fullscreen

# === LAYOUT ===
super + shift + space
    bspc node -s biggest

super + b
    bspc desktop -b

# === FOCUS ===
super + left
    bspc node -f west

super + right
    bspc node -f east

super + up
    bspc node -f north

super + down
    bspc node -f south

super + h
    bspc node -f west

super + j
    bspc node -f south

super + k
    bspc node -f north

super + l
    bspc node -f east

# === MOVE ===
super + shift + left
    bspc node -m west

super + shift + right
    bspc node -m east

super + shift + up
    bspc node -m north

super + shift + down
    bspc node -m south

super + shift + h
    bspc node -m west

super + shift + j
    bspc node -m south

super + shift + k
    bspc node -m north

super + shift + l
    bspc node -m east

# === WORKSPACES ===
super + 1
    bspc desktop -f 1

super + 2
    bspc desktop -f 2

super + 3
    bspc desktop -f 3

super + 4
    bspc desktop -f 4

super + 5
    bspc desktop -f 5

super + 6
    bspc desktop -f 6

super + 7
    bspc desktop -f 7

super + 8
    bspc desktop -f 8

super + 9
    bspc desktop -f 9

super + 0
    bspc desktop -f 10

super + shift + 1
    bspc node -d 1

super + shift + 2
    bspc node -d 2

super + shift + 3
    bspc node -d 3

super + shift + 4
    bspc node -d 4

super + shift + 5
    bspc node -d 5

super + shift + 6
    bspc node -d 6

super + shift + 7
    bspc node -d 7

super + shift + 8
    bspc node -d 8

super + shift + 9
    bspc node -d 9

super + shift + 0
    bspc node -d 10

# === RESIZE ===
super + alt + left
    bspc node -z left -20 0

super + alt + right
    bspc node -z right 20 0

super + alt + up
    bspc node -z top 0 -20

super + alt + down
    bspc node -z bottom 0 20

super + alt + h
    bspc node -z left -20 0

super + alt + l
    bspc node -z right 20 0

super + alt + k
    bspc node -z top 0 -20

super + alt + j
    bspc node -z bottom 0 20

# === SYSTEM ===
super + Escape
    wlogout

super + shift + Escape
    bspc quit

super + ctrl + r
    ~/.config/bspwm/bspwmrc &

# === VOLUME ===
XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%

XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

# === BRIGHTNESS ===
XF86MonBrightnessUp
    brightnessctl s +5%

XF86MonBrightnessDown
    brightnessctl s 5%-

# === SCREENSHOT ===
Print
    maim -s -u | xclip -selection clipboard -t image/png

shift + Print
    maim -u | xclip -selection clipboard -t image/png

ctrl + Print
    scrot -s
