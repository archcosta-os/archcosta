# Bspwm main config

# === WORKSPACES ===
bspc monitor -d 1 2 3 4 5 6 7 8 9 0

# === RULES ===
bspc rule -r desktop='^1' state=tiled
bspc rule -r desktop='^2' state=tiled
bspc rule -r desktop='^3' state=tiled
bspc rule -r desktop='^4' state=tiled
bspc rule -r desktop='^5' state=tiled
bspc rule -r desktop='^6' state=tiled
bspc rule -r desktop='^7' state=tiled
bspc rule -r desktop='^8' state=tiled
bspc rule -r desktop='^9' state=tiled
bspc rule -r desktop='^10' state=tiled

# Floating apps
bspc rule -a mplayer state=floating
bspc rule -a pinentry state=floating
bspc rule -a gpick state=floating
bspc rule -a Pavucontrol state=floating
bspc rule -a Archlinux-tweak-tool state=floating
bspc rule -a Nm-connection-editor state=floating

# === CONFIG ===
bspc config border_width 2
bspc config window_gap 8
bspc config split_ratio 0.5
bspc config gapless_monocle true
bspc config pointer_motion_grab_window false
bspc config focus_follows_pointer true
bspc config click_to_focus any
bspc config remove_unplugged_monitors true
bspc config remove_disconnected_monitors true

# === COLORS ===
bspc config normal_border_color '#4b4b4b'
bspc config active_border_color '#7fdbca'
bspc config focused_border_color '#eb5251'
bspc config presel_border_color '#7fdbca'
bspc config urgent_border_color '#ff6b6b'
