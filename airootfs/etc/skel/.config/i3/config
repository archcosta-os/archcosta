set $mod Mod4

font pango:Noto Sans 11
set_from_resource $bg-color #1b1f23
set_from_resource $inactive-bg-color #2d333b
set_from_resource $text-color #d8dee9
set_from_resource $inactive-text-color #9aa5b1
set_from_resource $accent #5fa8ff

gaps inner 8
gaps outer 12

bindsym $mod+Return exec alacritty
bindsym $mod+d exec rofi -show drun
bindsym $mod+Shift+q kill
bindsym $mod+Shift+e exec \"systemctl poweroff\"
bindsym $mod+Shift+r restart

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bar {\n  status_command i3status\n  position top\n  tray_output primary\n  colors { background $bg-color; statusline $text-color; separator #8899aa; focused_workspace $accent $accent #0b1021; inactive_workspace $inactive-bg-color $inactive-bg-color $inactive-text-color; urgent_workspace #ff5555 #ff5555 #0b1021; }\n}\n

client.focused $accent $accent #0b1021 $accent $accent
client.unfocused $inactive-bg-color $inactive-bg-color $inactive-text-color $inactive-bg-color $inactive-bg-color
